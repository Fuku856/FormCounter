{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "version": "0.1.0",
  "default_locale": "ja",
  "minimum_chrome_version": "111",

  "permissions": ["storage"],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*", "https://docs.google.com/a/*/forms/*"],
      "js": ["src/common/defaults.js", "src/common/counter.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
