{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "version": "0.2.1",
  "default_locale": "ja",
  "minimum_chrome_version": "112",

  "permissions": ["storage"],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://docs.google.com/forms/*", "https://docs.google.com/a/*/forms/*"],
      "js": [
        "src/common/defaults.js",
        "src/common/counter.js",
        "src/content/fields.js",
        "src/content/position.js",
        "src/content/badge.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
